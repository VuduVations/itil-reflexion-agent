# ITIL Reflexion Agent Configuration

# Required: LLM API Key
ANTHROPIC_API_KEY=sk-ant-...

# LLM Settings (defaults shown)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514
ACTOR_TEMPERATURE=0.7
EVALUATOR_TEMPERATURE=0.3
REFLECTOR_TEMPERATURE=0.5

# Reflexion Loop Settings
MAX_ITERATIONS=3
SCORE_THRESHOLD=90

# Server Settings
PORT=8080
CORS_ORIGINS=https://vuduvations.io,https://www.vuduvations.io,http://localhost:3000

# Optional: ServiceNow MCP Integration
# Set this to connect to a ServiceNow MCP server for real ITSM data
# SERVICENOW_MCP_URL=http://localhost:8200

# Optional: MCP Server Port (for exposing ITIL tools)
# MCP_SERVER_PORT=8100
